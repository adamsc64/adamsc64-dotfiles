#!/usr/bin/env zsh

emulate -L zsh

url="$1"
if [ -z "$url" ]; then
    echo "Usage: get-transcript <video-url>" >&2
    exit 1
fi

yt_dlp="$HOME/.venvs/env3/bin/yt-dlp"
if [ ! -x "$yt_dlp" ]; then
    yt_dlp="$(command -v yt-dlp)"
fi
if [ -z "$yt_dlp" ]; then
    echo "yt-dlp not found" >&2
    exit 1
fi

tmpdir="$(mktemp -d)" || exit 1
cleanup() {
    rm -rf "$tmpdir"
}
trap cleanup EXIT

"$yt_dlp" \
    --skip-download \
    --write-sub \
    --write-auto-sub \
    --sub-langs "en.*,en,-live_chat" \
    --sub-format "vtt/srt/best" \
    -o "$tmpdir/%(id)s.%(ext)s" \
    "$url" >/dev/null || exit 1

subfile="$(find "$tmpdir" -type f \( -name '*.vtt' -o -name '*.srt' -o -name '*.ttml' \) | head -n 1)"
if [ -z "$subfile" ]; then
    echo "No subtitles found" >&2
    exit 1
fi

case "$subfile" in
    *.srt)
        awk '
            /^[0-9]+$/ { next }
            /^[0-9]{2}:[0-9]{2}:[0-9]{2}[,.][0-9]{3}[[:space:]]+-->[[:space:]]+[0-9]{2}:[0-9]{2}:[0-9]{2}[,.][0-9]{3}$/ { next }
            /^[[:space:]]*$/ { print ""; next }
            { print }
        ' "$subfile"
        ;;
    *)
        awk '
            /^WEBVTT/ { next }
            /^Kind:/ { next }
            /^Language:/ { next }
            /^[0-9]{2}:[0-9]{2}:[0-9]{2}\.[0-9]{3}[[:space:]]+-->[[:space:]]+[0-9]{2}:[0-9]{2}:[0-9]{2}\.[0-9]{3}/ { next }
            /^[0-9]{2}:[0-9]{2}\.[0-9]{3}[[:space:]]+-->[[:space:]]+[0-9]{2}:[0-9]{2}\.[0-9]{3}/ { next }
            /^[[:space:]]*$/ { print ""; next }
            {
                gsub(/<[^>]+>/, "", $0)
                print
            }
        ' "$subfile"
        ;;
esac